# Copia este fichero como secrets.toml y rellena tus valores
DATABASE_URL = "postgresql+psycopg://electsim:PASSWORD@localhost:5432/electsim_espana"
POSTGRES_USER = "electsim"
POSTGRES_PASSWORD = "PASSWORD"

# Ollama (conecta automáticamente si ollama serve está corriendo)
ELECTSIM_OLLAMA_MODEL = "qwen2.5:7b"
ELECTSIM_OLLAMA_FAST_MODEL = "llama3.2:3b"
ELECTSIM_OLLAMA_GENERAL_MODEL = "qwen2.5:7b"
ELECTSIM_OLLAMA_EMBEDDING_MODEL = "nomic-embed-text"

# Claude API fallback (opcional — activo si Ollama no responde)
# ANTHROPIC_API_KEY = "sk-ant-..."
