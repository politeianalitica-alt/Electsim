# ============================================================================
#  Delta de variables de entorno para el módulo Economía · Sprint 0
# ============================================================================
#
#  Este fichero documenta qué variables de entorno hay que AÑADIR al
#  `.env.example` principal y al `.env` de producción para activar los
#  conectores económicos definidos en `integrations/economy_connectors.py`.
#
#  IMPORTANTE: las siguientes variables YA EXISTEN en el `.env.example`
#  principal del proyecto. No las dupliques:
#
#    - ESIOS_API_TOKEN       (ya usado por el módulo energía existente)
#    - NEWSAPI_KEY           (ya usado por el agregador de noticias)
#    - GDELT_MAX_QUERIES     (ya usado por el módulo geopolítica)
#
# ============================================================================
#  VARIABLES NUEVAS A AÑADIR
# ============================================================================

# FRED · Federal Reserve Economic Data
# Registro gratuito · https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub · Cotizaciones IBEX-35 + calendario macro
# Registro gratuito · https://finnhub.io/register
FINNHUB_API_KEY=

# WTO · World Trade Organization Timeseries
# Registro · https://apiportal.wto.org
WTO_API_KEY=

# UN Comtrade · Comercio bilateral por capítulo HS
# Registro · https://comtradeapi.un.org
UNCOMTRADE_API_KEY=

# PortWatch IMF · Tráfico puertos
# Contacto · https://portwatch.imf.org (la mayoría de endpoints son públicos
# y NO requieren key; activa esta solo si IMF te otorga acceso premium)
PORTWATCH_API_KEY=

# Ember Energy · Mix energético + EU ETS
# Registro · https://ember-energy.org/data (endpoints públicos disponibles
# sin key; key necesaria solo para tier premium)
EMBER_API_KEY=

# Nasdaq Data Link · Datasets premium (heredero Quandl)
# Registro gratuito · https://data.nasdaq.com/sign-up
NASDAQ_DATA_LINK_KEY=

# Alpha Vantage · Cotizaciones equity/forex/commodities con histórico extenso
# Registro gratuito · https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# IATI · Cooperación al desarrollo (AOD)
# Registro · https://iatistandard.org
IATI_API_KEY=

# ============================================================================
#  APIs PÚBLICAS · NO REQUIEREN KEY (documentadas para referencia)
# ============================================================================
#
#  Estas fuentes están integradas en `economy_connectors.py` y NO necesitan
#  variable de entorno alguna. Se listan aquí solo para que un analista sepa
#  qué endpoints quedan disponibles directamente:
#
#  - INE Tempus3 (servicios.ine.es/wstempus/js/ES)
#       Series oficiales: IPC, EPA, PIB, ICC, IPI, afiliados Seguridad Social.
#
#  - BCE / ECB SDMX-JSON (data-api.ecb.europa.eu)
#       Tipos refinanciación BCE, Euribor 3M, agregados monetarios eurozona.
#
#  - Eurostat (ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data)
#       Comparativas UE5 (ES, DE, FR, IT, PT): PIB, HICP, desempleo.
#
#  - Seguridad Social · datos abiertos (vía Tempus3 INE, IDA 25066)
#       Afiliados por régimen y comunidad autónoma.
#
#  - OCDE SDMX-JSON (stats.oecd.org/sdmx-json/data)
#       Indicadores OECD comparativos extra para benchmarking.
#
#  - AMECO · Annual Macro-Economic database de la Comisión Europea
#       Proyecciones fiscales y de competitividad eurozona.
#
#  - Cohesión UE (cohesiondata.ec.europa.eu/api)
#       Fondos estructurales y de cohesión por programa y región.
#
#  - Google Trends · vía pytrends
#       Instalación: `pip install pytrends`
#       Sin key requerida, rate-limit propio de Google.
#
# ============================================================================
