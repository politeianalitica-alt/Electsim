# ─────────────────────────────────────────────────────────────────────────────
# ElectSim España — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://electsim:TU_PASSWORD@localhost:5432/electsim_espana
POSTGRES_USER=electsim
POSTGRES_PASSWORD=TU_PASSWORD

# MinIO (almacenamiento de objetos — opcional)
MINIO_USER=minioadmin
MINIO_PASSWORD=TU_MINIO_PASSWORD
MINIO_ENDPOINT=localhost:9000

# APIs externas (opcional)
ESIOS_API_TOKEN=
INE_API_KEY=

# Paths de datos
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed

# Logging
LOG_LEVEL=INFO

# Ingesta diaria dashboard electoral
ELECTSIM_ELECTORAL_ENABLED_SOURCES=ine_geografia,interior_resultados,wikipedia_polls,cis_monitor,prensa_encuestas
ELECTSIM_ELECTORAL_ELECTIONS_DAILY=2023:7
ELECTSIM_ELECTORAL_ELECTIONS_FULL=2023:7,2019:11,2019:4,2016:6,2015:12,2011:11,2008:3,2004:3,2000:3
ELECTSIM_ELECTORAL_VOLUME_DROP_WARN_PCT=0.35
ELECTSIM_ELECTORAL_RESULTS_CHANGE_WARN_PCT=0.02
ELECTSIM_ELECTORAL_DAILY_CRON=10 6 * * *
ELECTSIM_ELECTORAL_TIMEZONE=Europe/Madrid
ELECTSIM_ELECTORAL_SKIP_NOWCASTING=false
ELECTSIM_ELECTORAL_TRIGGERED_BY=local
