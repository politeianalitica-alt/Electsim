# ─────────────────────────────────────────────────────────────────────────────
# ElectSim España — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://electsim:electsim@localhost:5432/electsim_espana
POSTGRES_USER=electsim
POSTGRES_PASSWORD=electsim

# MinIO (almacenamiento de objetos — opcional)
MINIO_USER=minioadmin
MINIO_PASSWORD=TU_MINIO_PASSWORD
MINIO_ENDPOINT=localhost:9000

# APIs externas (opcional)
ESIOS_API_TOKEN=
INE_API_KEY=

# Paths de datos
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
MICRODATOS_DIR=./data/microdatos

# Logging
LOG_LEVEL=INFO

# API / Auth
ELECTSIM_DEV_MODE=true
ELECTSIM_API_JWT_SECRET=

# DB pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# LLM Provider (openai | anthropic | ollama | stub)
ELECTSIM_LLM_PROVIDER=ollama

# IA gerente backend local (ollama | openai | anthropic | stub)
ELECTSIM_BACK_MANAGER_PROVIDER=ollama
ELECTSIM_GITS_AMIGOS_ROOT=./gits amigos
ELECTSIM_GITS_INDEX=./data/processed/git_amigos_knowledge
ELECTSIM_AI_STORE=./data/processed/ai_knowledge

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ELECTSIM_OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ELECTSIM_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Ollama local
OLLAMA_BASE_URL=http://localhost:11434
ELECTSIM_OLLAMA_MODEL=politeia-brain:latest
ELECTSIM_OLLAMA_NUM_CTX=8192
ELECTSIM_OLLAMA_NUM_PREDICT=500
ELECTSIM_BACK_MANAGER_MAX_TOKENS=500
ELECTSIM_OLLAMA_KEEP_ALIVE=30m
ELECTSIM_OLLAMA_TOP_P=0.85
ELECTSIM_OLLAMA_REPEAT_PENALTY=1.08
ELECTSIM_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Embeddings
ELECTSIM_EMBEDDING_PROVIDER=ollama
ELECTSIM_EMBEDDING_MODEL=text-embedding-3-small

# IA local operativa
ELECTSIM_CHROMA_DIR=./data/processed/chroma_store
ELECTSIM_AI_EMBEDDING_BACKEND=ollama
ELECTSIM_AI_SEMANTIC_SEARCH=1
ELECTSIM_AI_VECTOR_SYNC=1
ELECTSIM_AI_ENRICH_SCRAPERS=1
ELECTSIM_AI_REASON_PIPELINES=1
ELECTSIM_SENTIMENT_BACKEND=auto
ELECTSIM_SPACY_AUTO_DOWNLOAD=0

# Media / Social APIs
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=
NEWSAPI_KEY=

# Anthropic model override
ANTHROPIC_MODEL=claude-opus-4-1

# ── Celery + Redis ─────────────────────────────────────────────────────────────
# Redis como broker y backend de resultados
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Flower (monitor web de tareas Celery) — puerto 5555
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_in_production

# ── Ollama modelos por funcion ────────────────────────────────────────────────
# Ya definidos arriba; estos son los sobreescritos por el scheduler:
OLLAMA_MODEL_RESUMEN=qwen3:8b
OLLAMA_MODEL_ENTIDADES=llama3.2:3b
OLLAMA_MODEL_EMBED=nomic-embed-text
OLLAMA_MODEL_ANALISIS=gemma3:12b

# Tamano de lotes del pipeline mediatico
MAX_ARTICULOS_POR_MEDIO=30
PIPELINE_OLLAMA_LOTE=50

# Multi-tenant feature flags
ELECTSIM_FEATURE_MULTICLIENTE=1
ELECTSIM_DEFAULT_CLIENTE_ID=1
ELECTSIM_FEATURE_MEMORIA=1
ELECTSIM_FEATURE_IMPACTO=1
ELECTSIM_FEATURE_TRACKER=1

ELECTSIM_FEATURE_VOTO_BLANDO=1
ELECTSIM_FEATURE_ANALOGIAS=1

# ── Módulo Geopolítica & RRII (D8) ────────────────────────────────────────────
# ACLED: registro gratuito en https://developer.acleddata.com/
ACLED_API_KEY=
ACLED_EMAIL=

# Telegram: crea un bot con @BotFather y obtén el chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GDELT (sin API key — gratuito)
# GDELT_MAX_QUERIES=6

# Pipeline Geo — frecuencias de actualización
GEO_OSINT_INTERVAL_HOURS=2
GEO_ACLED_CRON=0 3 * * *
GEO_BRIEFING_CRON=0 7 * * *

# ── Módulo Geopolítica v2 ─────────────────────────────────────────────────────
# UCDP GED: API publica y gratuita (https://ucdpapi.pcr.uu.se/)
# UCDP_TOKEN= (no requerido actualmente — API abierta)

# Thresholds de scoring
GEOPOLITICO_UMBRAL_CRITICO=80
GEOPOLITICO_UMBRAL_MUY_ALTO=65
GEOPOLITICO_UMBRAL_ALTO=50
GEOPOLITICO_UMBRAL_MODERADO=30

# GDELT tono de alerta (por debajo = alerta)
GDELT_TONO_ALERTA=-5.0

# Modelos LLM para enricher geopolitico (sobreescribe defaults)
ANTHROPIC_MODEL_GEO_CRITICO=claude-opus-4-1
ANTHROPIC_MODEL_GEO_MODERADO=claude-3-5-haiku-20241022
