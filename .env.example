# ─────────────────────────────────────────────────────────────────────────────
# ElectSim España — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://electsim:electsim@localhost:5432/electsim_espana
POSTGRES_USER=electsim
POSTGRES_PASSWORD=electsim

# MinIO (almacenamiento de objetos — opcional)
MINIO_USER=minioadmin
MINIO_PASSWORD=TU_MINIO_PASSWORD
MINIO_ENDPOINT=localhost:9000

# APIs externas (opcional)
ESIOS_API_TOKEN=
INE_API_KEY=

# Paths de datos
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
MICRODATOS_DIR=./data/microdatos

# Logging
LOG_LEVEL=INFO

# API / Auth
ELECTSIM_DEV_MODE=true
ELECTSIM_API_JWT_SECRET=

# DB pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# LLM Provider (openai | anthropic | ollama | stub)
ELECTSIM_LLM_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ELECTSIM_OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ELECTSIM_ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
ELECTSIM_OLLAMA_MODEL=llama3

# Embeddings
ELECTSIM_EMBEDDING_MODEL=text-embedding-3-small

# Media / Social APIs
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=
NEWSAPI_KEY=

# Anthropic model override
ANTHROPIC_MODEL=claude-opus-4-1

# Multi-tenant feature flag
ELECTSIM_FEATURE_MULTICLIENTE=0

ELECTSIM_FEATURE_VOTO_BLANDO=1
ELECTSIM_FEATURE_ANALOGIAS=1
