{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-ingest",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/daily-refresh",
      "schedule": "0 7 * * *"
    }
  ]
}
