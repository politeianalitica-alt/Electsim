# ──────────────────────────────────────────────────────────────────────
#  Politeia · Visual Oscar — Variables de entorno
#  Copia este archivo como `.env.local` para desarrollo, o configura en
#  Vercel (Settings → Environment Variables) para producción.
#
#  La app funciona con CUALQUIER subset de estas variables. Si una falta,
#  el subsistema correspondiente cae a un fallback determinista (mocks o
#  in-memory). Útil para previews y onboarding progresivo.
# ──────────────────────────────────────────────────────────────────────

# ─── Backend FastAPI (apps/api) ────────────────────────────────────────
BACKEND_URL=https://your-railway-app.up.railway.app
BACKEND_API_KEY=
BACKEND_TIMEOUT_MS=8000

# ─── Ollama (LLM provider) ─────────────────────────────────────────────
# Sin OLLAMA_URL → research/radar/exec-summary devuelven mocks.
OLLAMA_URL=https://ollama.tudominio.com
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TIMEOUT_MS=90000

# ─── Auth · Clerk ──────────────────────────────────────────────────────
# Sin CLERK_SECRET_KEY → modo DEV (usuario mock owner). DEV_MODE="true" lo
# fuerza explícitamente incluso si Clerk está configurado.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
DEV_MODE=true

# ─── Base de datos · Postgres (Neon recomendado) ───────────────────────
# Sin DATABASE_URL → la app usa el repositorio in-memory.
DATABASE_URL=
DATABASE_POOL_SIZE=10

# ─── Observabilidad · Sentry ───────────────────────────────────────────
# Sin SENTRY_DSN → captureException es no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Queue · Upstash QStash ────────────────────────────────────────────
# Sin estas variables → la cola es in-memory (no persistente entre cold starts).
UPSTASH_QSTASH_TOKEN=
UPSTASH_QSTASH_DESTINATION_URL=

# ─── Analytics · PostHog ───────────────────────────────────────────────
# Sin NEXT_PUBLIC_POSTHOG_KEY → track() es no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Cron security ─────────────────────────────────────────────────────
# Vercel cron envía Authorization: Bearer <CRON_SECRET> automáticamente
# si configuras esta variable. Las rutas /api/cron/* lo validan.
CRON_SECRET=

# ─── Misc ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Módulo Domo (Business Intelligence) ───────────────────────────────
# Sin NEXT_PUBLIC_DOMO_API_URL → todas las rutas /api/domo/* devuelven mocks
# deterministas. Útil para preview, onboarding y desarrollo del frontend
# antes de tener el backend Python listo.
NEXT_PUBLIC_DOMO_API_URL=http://localhost:8000
DOMO_POSTGRES_URL=
LITELLM_API_URL=
DOMO_WEBHOOK_SECRET=

# ─── OSINT / Compliance ─────────────────────────────────────────────────
# OpenCorporates · 120M+ empresas en 130 jurisdicciones
# https://api.opencorporates.com/documentation/API-Reference
# Free tier 500 req/mes. Sin key = sólo búsquedas públicas limitadas.
OPENCORPORATES_API_KEY=

# OpenSanctions · 333+ listas (OFAC, EU FSF, UNSC, UK OFSI, PEPs, ...)
# https://api.opensanctions.org/docs
# Sin key = API pública rate-limited (~60 req/min). Con key = paid tier.
OPENSANCTIONS_API_KEY=

# ─── Energía · GIE AGSI+ (almacenamiento de gas EU/ES) ──────────────────
# Sector Energía → pestaña Gas → panel "Almacenamiento de gas".
# La API de GIE AGSI+ (agsi.gie.eu) es GRATUITA pero exige una API key
# (obligatoria desde 2022). Regístrate gratis en https://agsi.gie.eu/account
# y pega aquí (o en Vercel) tu key. Sin ella, el panel de almacenamiento
# muestra un empty-state pidiendo configurarla; el resto de la vista Gas
# (precios, GNL, empresas) sigue operativa.
GIE_API_KEY=
