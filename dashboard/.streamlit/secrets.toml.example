# secrets.toml.example — copia como secrets.toml para desarrollo local
# En Streamlit Cloud: pega el contenido en Settings → Secrets
# NUNCA subas secrets.toml al repositorio (ya está en .gitignore)

DATABASE_URL = "postgresql+psycopg://electsim:PASSWORD@localhost:5432/electsim_espana"
DATA_DIR     = "/tmp/electsim"
LOG_LEVEL    = "WARNING"

